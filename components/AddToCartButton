'use client'
import { useCart } from '@/context/CartContext'

export default function AddToCartButton({ product }: any) {
  const { addItem } = useCart()
  return (
    <button
      onClick={() => addItem({ id: product.id, name: product.name, price: product.price, image: product.image_url, quantity: 1 })}
      className="bg-amber-600 hover:bg-amber-700 text-white px-6 py-3 rounded-lg w-full md:w-auto"
    >
      أضف إلى السلة
    </button>
  )
}